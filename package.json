{
  "name": "tuneloop",
  "version": "0.1.0",
  "description": "Local analytics for your AI coding sessions. Count outcomes, not tokens.",
  "license": "MIT",
  "author": "Tuneloop (https://tuneloop.io)",
  "homepage": "https://github.com/Relvy-AI/tuneloop#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Relvy-AI/tuneloop.git"
  },
  "bugs": {
    "url": "https://github.com/Relvy-AI/tuneloop/issues"
  },
  "type": "module",
  "bin": {
    "tuneloop": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "node scripts/clean.mjs",
    "build": "tsup",
    "dev": "tsup && tsx src/cli.ts",
    "watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:client": "tsc -p src/server/client --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "codex",
    "ai",
    "ai-agents",
    "analytics",
    "llm",
    "observability",
    "developer-tools",
    "tuneloop"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "better-sqlite3": "^12.11.1",
    "commander": "^12.1.0",
    "openai": "^6.44.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.11.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
